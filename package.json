    "@types/node": "^22.20.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/ui": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
